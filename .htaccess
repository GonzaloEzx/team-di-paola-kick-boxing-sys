Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(config|database|docs|ejemplo)(/|$) - [F,L]
</IfModule>

<IfModule mod_authz_core.c>
    <FilesMatch "^(\.git|\.env|\.gitignore|composer\.(json|lock)|package(-lock)?\.json)$">
        Require all denied
    </FilesMatch>
</IfModule>
